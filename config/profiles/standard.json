{
  "_comment": "Recommended profile. Token limits, OTEL monitoring, safe tool permissions.",
  "env": {
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "29000",
    "CLAUDE_CODE_FILE_READ_MAX_OUTPUT_TOKENS": "25000",
    "MAX_THINKING_TOKENS": "25999",
    "MAX_MCP_OUTPUT_TOKENS": "20000",
    "BASH_MAX_OUTPUT_LENGTH": "30000",
    "TASK_MAX_OUTPUT_LENGTH": "30000",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1",
    "DISABLE_COST_WARNINGS": "1",
    "MCP_TIMEOUT": "60000",
